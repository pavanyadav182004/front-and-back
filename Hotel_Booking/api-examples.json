      "description": "Premium stay with lake view rooms.",
      "pricePerNight": 4200,
      "rating": 4.6,
      "imageUrl": "https://images.unsplash.com/photo-1566073771259-6a8506099945",
      "roomType": "Luxury Room",
      "available": true,
      "amenities": ["Free Wi-Fi", "Room Service", "Free Breakfast"]
    }
  },
  "checkAvailableRooms": {
    "method": "GET",
    "url": "http://localhost:8082/api/rooms/available?hotelId=1&checkIn=2026-05-10&checkOut=2026-05-12"
  },
  "createBookingUser": {
    "method": "POST",
    "url": "http://localhost:8082/api/bookings",
    "headers": {
      "Authorization": "Bearer USER_TOKEN"
    },
    "body": {
      "hotelId": 1,
      "roomId": 1,
      "checkIn": "2026-05-10",
      "checkOut": "2026-05-12",
      "guests": 2
    }
  },
  "confirmPayment": {
    "method": "POST",
    "url": "http://localhost:8082/api/payments",
    "headers": {
      "Authorization": "Bearer USER_TOKEN"
    },
    "body": {
      "bookingId": 1
    }
  },
  "adminBookings": {
    "method": "GET",
    "url": "http://localhost:8082/api/bookings/admin",
    "headers": {
      "Authorization": "Bearer ADMIN_TOKEN"
    }
  },
